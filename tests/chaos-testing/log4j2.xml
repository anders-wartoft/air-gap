<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{yyyy-MM-dd'T'HH:mm:ss.SSSX} %-5p [%t] %c{1} - %m%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="org.apache.kafka.common.utils.AppInfoParser" level="off"/>
    <Logger name="org.apache.kafka.common.metrics.Metrics" level="off"/>
    <Logger name="org.apache.kafka.clients.admin.AdminClientConfig" level="off"/>
    <Root level="warn">
    <!--><Root level="info"></!-->

      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
